{
  "name": "modern-wars-2",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "description": "Risk-style real-time strategy map game — Spectator/AI mode (Modern Wars 2.0)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "build:world": "tsx scripts/build-world.ts",
    "build:fixture": "tsx scripts/build-fixture.ts",
    "build:atlas": "tsx scripts/build-atlas.ts",
    "preview": "vite preview",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "test:unit": "vitest run",
    "bench:headless": "tsx scripts/bench-headless.ts",
    "check:bundle": "tsx scripts/check-bundle.ts"
  },
  "dependencies": {
    "immer": "^10.1.1",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "8.6.6",
    "rbush": "^4.0.1",
    "react": "^18.3.1",
    "react-dom": "^18.3.1",
    "seedrandom": "^3.0.5",
    "tone": "^15.0.4",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@turf/rewind": "^7.1.0",
    "@types/node": "^22.7.4",
    "@types/react": "^18.3.11",
    "@types/react-dom": "^18.3.0",
    "@types/seedrandom": "^3.0.8",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "@vitejs/plugin-react": "^4.3.2",
    "earcut": "^3.0.0",
    "eslint": "^8.57.1",
    "eslint-plugin-react-hooks": "^4.6.2",
    "eslint-plugin-react-refresh": "^0.4.12",
    "rollup-plugin-visualizer": "^5.12.0",
    "shpjs": "^6.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5",
    "vite": "^7.0.0",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
