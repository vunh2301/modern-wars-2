{
  "name": "modern-wars-hex",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Modern Wars — Hex Map Renderer (SPEC v1.0)",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "preview": "vite preview --port 4173",
    "lint": "eslint . --ext .ts,.tsx --max-warnings=0",
    "typecheck": "tsc --noEmit",
    "bake": "tsx scripts/bake-hex-tiers.ts",
    "test": "vitest run"
  },
  "dependencies": {
    "honeycomb-grid": "^4.1.5",
    "pixi-viewport": "^6.0.3",
    "pixi.js": "8.6.6",
    "rbush": "^4.0.1",
    "zustand": "^4.5.5"
  },
  "devDependencies": {
    "@types/node": "^22.7.4",
    "@typescript-eslint/eslint-plugin": "^8.8.1",
    "@typescript-eslint/parser": "^8.8.1",
    "eslint": "^8.57.1",
    "shpjs": "^6.2.0",
    "tsx": "^4.19.1",
    "typescript": "^5.4.5",
    "vite": "^7.0.0",
    "vitest": "^2.1.2"
  },
  "engines": {
    "node": ">=20"
  }
}
